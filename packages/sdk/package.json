{
  "name": "deploy.me",
  "version": "0.2.0",
  "description": "TypeScript client + builders for deploy.me",
  "license": "MIT",
  "author": "Lyndon Leong <lyndon@lambda.run>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lantos1618/deploy-me-sdk.git"
  },
  "homepage": "https://deploy.me",
  "type": "module",
  "main": "dist/index.js",
