{
  "name": "@deploy-me/cli",
  "version": "0.2.0",
  "description": "deploy.me CLI · the `deploy` binary (alias `dm`, legacy `dp`)",
  "license": "MIT",
  "author": "Lyndon Leong <lyndon@lambda.run>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lambda-run/deploy-me-packages.git",
    "directory": "packages/cli"
  },
  "homepage": "https://deploy.me",
  "type": "module",
  "bin": {
    "deploy": "./dist/bin/deploy.js",
    "dm":     "./dist/bin/deploy.js",
    "dp":     "./dist/bin/deploy.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin/deploy.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "dev": "bun src/bin/deploy.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@deploy-me/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
